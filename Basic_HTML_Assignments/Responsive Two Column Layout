<!DOCTYPE html>
<html>
<head>
<title>Two Column Layout</title>

<style>

.container{
display:flex;
}

.left{
width:30%;
background:lightgray;
padding:20px;
}

.right{
width:70%;
padding:20px;
}

@media(max-width:768px){
.container{
flex-direction:column;
}
}

</style>

</head>

<body>

<div class="container">

<div class="left">
<h3>Sidebar</h3>
<p>Links or menu here</p>
</div>

<div class="right">
<h2>Main Content</h2>
<p>This is the main content area.</p>
</div>

</div>

</body>
</html>
