<!DOCTYPE html>
<html>
<head>
<title>Hover Card</title>

<style>

.card{
width:200px;
padding:20px;
border:1px solid gray;
transition:transform 0.3s;
}

.card:hover{
transform:translateY(-10px);
}

</style>

</head>

<body>

<div class="card">

<h3>Profile</h3>

<p>This card moves up on hover.</p>

</div>

</body>
</html>
