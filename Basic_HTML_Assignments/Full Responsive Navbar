<!DOCTYPE html>
<html>
<head>
<title>Responsive Navbar</title>

<style>

.nav{
display:flex;
justify-content:space-between;
background:black;
color:white;
padding:10px;
}

.menu{
display:flex;
gap:15px;
}

@media(max-width:768px){

.menu{
display:none;
}

}

</style>

</head>

<body>

<div class="nav">

<h3>Logo</h3>

<div class="menu">
<p>Home</p>
<p>About</p>
<p>Services</p>
<p>Contact</p>
</div>

</div>

</body>
</html>
