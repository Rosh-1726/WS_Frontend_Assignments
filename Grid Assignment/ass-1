<!DOCTYPE html>
<html>
<head>
<title>Assignment 1 - Basic Grid</title>

<style>

body{
  display:flex;
  justify-content:center;
  align-items:center;
  height:100vh;
}

.container{
  display:grid;
  grid-template-columns:repeat(3,100px);
  grid-template-rows:repeat(3,100px);
  gap:10px;
}

.box{
  background:coral;
}

</style>
</head>

<body>

<div class="container">

<div class="box"></div>
<div class="box"></div>
<div class="box"></div>
<div class="box"></div>
<div class="box"></div>
<div class="box"></div>
<div class="box"></div>
<div class="box"></div>
<div class="box"></div>

</div>

</body>
</html>
